# ── Gemini AI (required for AI features) ──────────────────────────
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ── Neon Database (required for persistent data storage) ──────────
# Create a free DB at https://neon.tech — copy the connection string
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# ── Cloudinary (required for persistent image/video storage) ──────
# Create a free account at https://cloudinary.com
CLOUDINARY_CLOUD_NAME="my_cloud_name"
CLOUDINARY_API_KEY="my_api_key"
CLOUDINARY_API_SECRET="my_api_secret"

# ── App URL (injected automatically in AI Studio) ─────────────────
APP_URL="MY_APP_URL"
